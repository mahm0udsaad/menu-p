# ─────────────────────────────────────────────────────────────
# menu-p — environment variables
# Copy this file to `.env.local` and fill in the values:
#     cp .env.example .env.local
#
# The NEXT_PUBLIC_SUPABASE_* values below are the public client keys
# for the `menu-p` Supabase project (they are shipped to the browser
# anyway, so they are safe to commit). Everything marked CHANGE_ME is
# a secret you must supply yourself for that feature to work.
# ─────────────────────────────────────────────────────────────

# ── Supabase (REQUIRED — app boots with a stub without these) ──
NEXT_PUBLIC_SUPABASE_URL=https://qsjbthmydzcwogjgyarp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InFzamJ0aG15ZHpjd29namd5YXJwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODEwMzUwMzEsImV4cCI6MjA5NjYxMTAzMX0.7hFJ0l_wE30ZFfvEU5W6PvCiENda7VAg1yITHYv9WGw

# ── App URLs ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Google Generative AI (for AI menu features) ──
GOOGLE_GENERATIVE_AI_API_KEY=CHANGE_ME
# Optional model overrides:
# GEMINI_TEXT_MODEL=
# GEMINI_IMAGE_MODEL=

# ── Paymob payments (optional — only needed for checkout flows) ──
PAYMOB_API_KEY=CHANGE_ME
PAYMOB_SECRET_KEY=CHANGE_ME
PAYMOB_INTEGRATION_ID=CHANGE_ME
NEXT_PUBLIC_PAYMOB_IFRAME_ID=CHANGE_ME
PAYMOB_REDIRECT_URL=http://localhost:3000/payment/callback
PAYMOB_NOTIFICATION_URL=http://localhost:3000/api/paymob/webhook

# ── Email / SMTP (optional) ──
SMTP_HOST=CHANGE_ME
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME

# ── Social integrations (optional) ──
META_APP_ID=CHANGE_ME
META_APP_SECRET=CHANGE_ME
TIKTOK_CLIENT_KEY=CHANGE_ME
TIKTOK_CLIENT_SECRET=CHANGE_ME
SOCIAL_TOKEN_KEY=CHANGE_ME
# Set to "1" to mock social posting in local dev:
SOCIAL_MOCK=1

# ── PDF generation (optional tuning) ──
# PDF_GENERATION_TIMEOUT=60000
# PDF_NAVIGATION_TIMEOUT=30000
# NEXT_PUBLIC_PDF_BASE_URL=
